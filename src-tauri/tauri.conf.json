{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Playlist Downloader",
  "version": "0.1.0",
  "identifier": "com.ytplaylist.downloader",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "YT Playlist Downloader",
        "width": 980,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://i.ytimg.com https://ui-avatars.com https://*.googleusercontent.com data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.googleapis.com; media-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
